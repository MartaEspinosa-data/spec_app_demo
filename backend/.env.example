# Backend Environment Variables
# Copy this file to .env and fill in your values

# Frontend URL (for CORS and email links, and Stripe redirect)
FRONTEND_URL=http://localhost:5173

# Database (defaults to SQLite)
# DATABASE_URL=sqlite:///./sql_app.db

# Email Configuration (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# Teacher login credentials
TEACHER_EMAIL=your-teacher-email@gmail.com
# Generate a bcrypt hash using: POST /api/teachers/setup-password
TEACHER_PASSWORD=

# ── Stripe — Payment Links ──────────────────────────────────────────────────
# Get your secret key from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Get your webhook secret from https://dashboard.stripe.com/webhooks
# (create an endpoint pointing to https://your-domain.com/api/v1/webhooks/stripe
#  listening to the event: checkout.session.completed)
STRIPE_WEBHOOK_SECRET=whsec_...

# Pre-built Stripe Payment Links (created in Stripe Dashboard)
# The app appends ?client_reference_id={lesson_id}&prefilled_email={email}
# to link each payment back to the correct lesson.
#   STRIPE_PAYMENT_LINK_30 → 30 min lesson
#   STRIPE_PAYMENT_LINK_45 → 45 min lesson
#   STRIPE_PAYMENT_LINK_60 → 60 min lesson
STRIPE_PAYMENT_LINK_30=https://buy.stripe.com/test_...
STRIPE_PAYMENT_LINK_45=https://buy.stripe.com/test_...
STRIPE_PAYMENT_LINK_60=https://buy.stripe.com/test_...

# JWT Secret (generate a strong random string for production)
# python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-in-production-use-a-strong-random-secret
